# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# EmailBison
EMAILBISON_BASE_URL="https://send.brokerstaffer.com"
EMAILBISON_API_KEY=""
EMAILBISON_WEBHOOK_SECRET=""

# Instantly (v2 API)
INSTANTLY_BASE_URL="https://api.instantly.ai/api/v2"
INSTANTLY_API_KEY=""
INSTANTLY_WEBHOOK_SECRET=""

# Unipile
UNIPILE_DSN="api43.unipile.com:17337"
UNIPILE_API_KEY=""

# AI defaults (workspace-level overrides stored encrypted in DB)
OPENAI_API_KEY=""

# Redis / BullMQ (used by the worker; not required for Phase 1)
REDIS_URL=""

# Secrets — used to encrypt API keys / OAuth tokens before storing
APP_ENCRYPTION_KEY=""

# Super admin emails (comma-separated). Receive owner role on the singleton workspace.
SUPER_ADMIN_EMAILS="admin@outreachify.io"

# Optional: secret guarding /api/webhooks/register (falls back to SUPABASE_SERVICE_ROLE_KEY)
WEBHOOK_REGISTER_SECRET=""
